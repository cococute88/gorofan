# ============================================================
# AI Creative Workspace — 환경변수 템플릿 (.env.example)
# 실제 값은 .env 로 복사해 채운다. .env 는 절대 커밋 금지.
# ============================================================

# --- core ---
APP_ENV=local                       # local | dev | prod
# 32+ 바이트 무작위 문자열. 암호화/JWT 서명에 사용. 분실 시 암호화 데이터 복호 불가.
APP_SECRET_KEY=change-me-to-a-long-random-secret-string-please
DATABASE_URL=sqlite+aiosqlite:///./data/app.db   # PG 예: postgresql+asyncpg://user:pass@db:5432/app

# --- auth (FR-AUTH-2) ---
AUTH_ENABLED=false                  # false=로컬 단일 사용자(default-user) 모드
JWT_ALG=HS256
JWT_TTL_SECONDS=2592000             # 30d (access). refresh 쿠키는 별도.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8000   # 콜백 URL 베이스

# --- providers / runtime ---
PROVIDER_MAX_CONCURRENCY=4
PROVIDER_TIMEOUT_SECONDS=60

# --- storage / jobs ---
MEDIA_ROOT=./data/media
STORAGE_BACKEND=local               # local | s3
JOB_BACKEND=inproc                  # inproc | celery | arq
MAX_UPLOAD_BYTES=5242880            # 5MB

# --- cors ---
CORS_ORIGINS=http://localhost:3000

# --- frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
